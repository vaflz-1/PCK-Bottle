{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Godot PCK Studio",
  "version": "1.0.0",
  "identifier": "com.godotpckstudio.studio",
  "build": {
    "beforeDevCommand": "npm run serve",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:4173",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Godot PCK Studio",
        "width": 1240,
        "height": 780,
        "minWidth": 920,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src ipc: http://ipc.localhost; object-src 'none'; base-uri 'none'; frame-src 'none'; form-action 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  }
}
